# TripSage Next.js + AI SDK v6 environment template (server-first)
# WARNING: This file is a template only and must never be used as-is in production.
# Replace placeholder values with your own secrets before running locally or deploying.

# ---------------------------------------------------------------------------
# Core URLs
# ---------------------------------------------------------------------------
NODE_ENV=development
CI=false
PORT=3000
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Client telemetry is opt-in to avoid noisy console errors when a local collector isn't running.
NEXT_PUBLIC_OTEL_CLIENT_ENABLED=false
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TripSage
NEXT_PUBLIC_BASE_PATH=
# Optional external CSP report collector. Defaults to /api/security/csp-report.
CSP_REPORT_URI=

# ---------------------------------------------------------------------------
# Streamdown (Markdown rendering)
# ---------------------------------------------------------------------------
# Optional: comma-separated prefix allowlists (extends built-in defaults).
NEXT_PUBLIC_STREAMDOWN_ALLOWED_IMAGE_PREFIXES=
NEXT_PUBLIC_STREAMDOWN_ALLOWED_LINK_PREFIXES=

# ---------------------------------------------------------------------------
# Remote image proxy (server-only)
# ---------------------------------------------------------------------------
# Comma-separated host allowlist for GET /api/images/proxy (https-only).
# Example: googleusercontent.com,images.examplecdn.com
IMAGE_PROXY_ALLOWED_HOSTS=
# Optional: override remote image max bytes (default 10MB, capped at 25MB).
IMAGE_PROXY_MAX_BYTES=

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Optional: storage proxy URL (use on WSL if /storage/v1 returns 500 on 54321).
SUPABASE_STORAGE_URL=
# Public key (set ONE):
# - Canonical: publishable key (sb_publishable_...)
# - Legacy fallback: anon key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=changeme-min-32-chars-xxxxxxxxxxxxxxxx
DATABASE_URL=postgresql://placeholder-user:placeholder-password@localhost:5432/postgres
MFA_BACKUP_CODE_PEPPER=changeme-min-16-chars

# Supabase vector tuning (pgvector/pg_cron) — consumed by supabase/migrations/20260120000000_base_schema.sql
PGVECTOR_HNSW_M=32
PGVECTOR_HNSW_EF_CONSTRUCTION=180
PGVECTOR_HNSW_EF_SEARCH_DEFAULT=96
MEMORIES_RETENTION_DAYS=180

# ---------------------------------------------------------------------------
# Upstash / QStash (HTTP-only)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# Idempotency: set to "false" to fail closed when Redis is unavailable (default is fail-open)
IDEMPOTENCY_FAIL_OPEN=true
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-qstash-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key

# ---------------------------------------------------------------------------
# AI providers / gateway
# ---------------------------------------------------------------------------
# Optional comma-separated host allowlist for non-default AI_GATEWAY_URL values.
# Use hostnames only; do not include a scheme, path, or port.
# Example: ai-gateway.vercel.sh,gateway.internal.example
AI_GATEWAY_ALLOWED_HOSTS=
AI_GATEWAY_API_KEY=
AI_GATEWAY_URL=
ANTHROPIC_API_KEY=
BYOK_HEALTHCHECK_KEY=
EMBEDDINGS_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_AI_API_KEY=
XAI_API_KEY=

# ---------------------------------------------------------------------------
# Search / crawling
# ---------------------------------------------------------------------------
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2

# ---------------------------------------------------------------------------
# Maps / weather
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here" # Shared Google Maps API key (server only)
GOOGLE_MAPS_SERVER_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_API_KEY=
OPENWEATHERMAP_API_KEY=

# ---------------------------------------------------------------------------
# Payments
# ---------------------------------------------------------------------------
# Set all three when enabling payments; leave all unset when payments are disabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---------------------------------------------------------------------------
# Email / notifications
# ---------------------------------------------------------------------------
# Set all Resend values when enabling email notifications; leave all unset when disabled.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=
COLLAB_WEBHOOK_URL=
HMAC_SECRET=
# Telemetry secrets (optional, but if set must be ≥32 chars for cryptographic security)
# - TELEMETRY_AI_DEMO_KEY: Authenticates AI demo endpoint requests
# - TELEMETRY_HASH_SECRET: HMAC secret for hashing telemetry identifiers
# App fails to start if either is set to fewer than 32 characters.
TELEMETRY_AI_DEMO_KEY=
TELEMETRY_HASH_SECRET=

# ---------------------------------------------------------------------------
# Travel APIs
# ---------------------------------------------------------------------------
# Set all Amadeus values when enabling Amadeus-backed flight search; leave all unset when disabled.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=
DUFFEL_ACCESS_TOKEN=
DUFFEL_API_KEY=
EPS_API_KEY=
EPS_API_SECRET=
EPS_BASE_URL=https://api.ean.com/2/rapid
EPS_DEFAULT_CUSTOMER_IP=0.0.0.0
EPS_DEFAULT_USER_AGENT=TripSage/1.0 (+https://tripsage.ai)

# ---------------------------------------------------------------------------
# Analytics (optional)
# ---------------------------------------------------------------------------
GOOGLE_ANALYTICS_ID=
MIXPANEL_TOKEN=
POSTHOG_HOST=https://app.posthog.com
POSTHOG_KEY=

# ---------------------------------------------------------------------------
# Flags
# ---------------------------------------------------------------------------
ANALYZE=false
DEBUG=false
ENABLE_AI_DEMO=false
