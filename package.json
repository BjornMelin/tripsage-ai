{
  "name": "tripsage-ai-frontend",
  "version": "1.32.2",
  "private": true,
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "pnpm build && next experimental-analyze --output",
    "start": "node .next/standalone/server.js",
    "prepare": "simple-git-hooks",
    "biome:check": "biome check ./src ./e2e ./scripts",
    "biome:fix": "biome check ./src ./e2e ./scripts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:short": "vitest run --test-timeout=3000 --hook-timeout=3000 --teardown-timeout=3000",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage.enabled --coverage.provider=v8 && node scripts/check-coverage-critical.mjs",
    "test:benchmark": "node scripts/run-benchmark.mjs",
    "test:ai-model-smoke": "node scripts/ai-model-smoke.mjs",
    "test:quick": "vitest run --reporter=dot",
    "test:ci": "vitest run --reporter=dot --reporter=github-actions",
    "test:unit": "vitest run --project=unit",
    "test:schemas": "vitest run --project=schemas",
    "test:components": "vitest run --project=component",
    "test:api": "vitest run --project=api",
    "test:integration": "vitest run --project=integration",
    "test:shard": "vitest run --reporter=blob --shard=$VITEST_SHARD",
    "test:pr": "vitest run --changed origin/main --passWithNoTests",
    "test:upstash:unit": "vitest run src/test/upstash/upstash.unit.test.ts",
    "test:upstash:int": "UPSTASH_USE_EMULATOR=1 vitest run --project=integration src/__tests__/contracts/upstash-int.integration.test.ts",
    "test:upstash:smoke": "UPSTASH_SMOKE=1 vitest run --project=integration src/__tests__/contracts/upstash.smoke.integration.test.ts",
    "test:changed": "vitest run --changed",
    "test:affected": "vitest run --changed --passWithNoTests && git diff -z --name-only HEAD -- 'src/**/*.ts' 'src/**/*.tsx' ':!**/*.test.ts' ':!**/*.test.tsx' | xargs -0 -r vitest related --run --passWithNoTests",
    "test:coverage:shard": "VITEST_COVERAGE_SKIP_THRESHOLDS=1 vitest run --coverage.enabled --coverage.provider=v8 --reporter=blob --shard=$VITEST_SHARD",
    "test:merge": "vitest --merge-reports",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test --project=chromium e2e/critical-flows.spec.ts",
    "test:e2e:chromium": "playwright test --project=chromium",
    "supabase:start": "tsx scripts/supabase/start.ts",
    "supabase:stop": "tsx scripts/supabase/stop.ts",
    "supabase:status": "pnpm dlx supabase@2.102.0 status",
    "supabase:db:reset": "tsx scripts/supabase/db-reset.ts",
    "supabase:bootstrap": "tsx scripts/supabase/bootstrap.ts",
    "supabase:seed:dev": "tsx scripts/seed/supabase-local.ts --profile=dev",
    "supabase:seed:e2e": "tsx scripts/seed/supabase-local.ts --profile=e2e",
    "supabase:seed:payments": "tsx scripts/seed/supabase-local.ts --profile=payments",
    "supabase:seed:calendar": "tsx scripts/seed/supabase-local.ts --profile=calendar",
    "supabase:seed:edge-cases": "tsx scripts/seed/supabase-local.ts --profile=edge-cases",
    "supabase:reset:dev": "pnpm supabase:db:reset && pnpm supabase:seed:dev",
    "supabase:reset:e2e": "pnpm supabase:db:reset && pnpm supabase:seed:e2e",
    "supabase:reset:payments": "pnpm supabase:db:reset && pnpm supabase:seed:payments",
    "supabase:reset:calendar": "pnpm supabase:db:reset && pnpm supabase:seed:calendar",
    "supabase:reset:edge-cases": "pnpm supabase:db:reset && pnpm supabase:seed:edge-cases",
    "supabase:typegen": "pnpm dlx supabase@2.102.0 gen types --lang typescript --local --schema auth --schema public --schema memories --schema storage > src/lib/supabase/database.types.ts",
    "deploy:check-env": "node scripts/verify-production-env.mjs",
    "deploy:smoke": "node scripts/vercel-deploy-smoke.mjs",
    "docs:check": "node scripts/check-doc-links.mjs",
    "test:smoke:live": "node scripts/vercel-deploy-smoke.mjs",
    "ops": "tsx scripts/ops.ts",
    "test:analyze": "pnpm ops test analyze failures",
    "test:analyze:all": "pnpm ops test analyze all",
    "boundary:check": "node scripts/check-boundaries.mjs",
    "ai-tools:check": "node scripts/check-ai-tools.mjs",
    "check:fileoverviews": "node scripts/check-fileoverviews.mjs",
    "check:fileoverviews:full": "node scripts/check-fileoverviews.mjs --full",
    "check:no-new-domain-infra-imports": "node scripts/check-no-new-domain-infra-imports.mjs",
    "check:no-new-unknown-casts": "node scripts/check-no-new-unknown-casts.mjs",
    "check:no-secrets": "node scripts/check-no-secrets.mjs",
    "check:no-secrets:staged": "node scripts/check-no-secrets.mjs --staged",
    "check:no-secrets:full": "node scripts/check-no-secrets.mjs --full",
    "check:otel-convergence": "node scripts/check-otel-convergence.mjs",
    "check:no-unknown-casts": "node scripts/check-no-unknown-casts.mjs",
    "check:api-route-errors": "node scripts/check-api-route-errors.mjs",
    "check:api-route-errors:full": "node scripts/check-api-route-errors.mjs --full",
    "check:zod-v4": "node scripts/check-zod-v4-usage.mjs",
    "check:zod-v4:full": "node scripts/check-zod-v4-usage.mjs --full",
    "deps:audit": "knip --dependencies",
    "deps:audit:prod": "knip --production --dependencies",
    "deps:fix": "knip --fix --dependencies",
    "deps:report": "knip --dependencies --no-exit-code",
    "deps:report:prod": "knip --production --dependencies --no-exit-code",
    "deps:cycles": "madge --circular --extensions ts,tsx --ts-config ./tsconfig.json src/ai/agents"
  },
  "simple-git-hooks": {
    "pre-commit": "node scripts/check-no-secrets.mjs --staged"
  },
